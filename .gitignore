# OpenChess .gitignore

# Arduino build artifacts
firmware/**/build/
firmware/**/*.elf
firmware/**/*.hex
firmware/**/*.bin

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
*.code-workspace

# Large binary files (use Git LFS or add manually)
*.stl
*.3mf
*.step
upstream-firmware/

# Local firmware build sketch (symlinks + Arduino build artifacts)
build-sketch/

# Environment (added by audit 2026-05-10)
.env
.env.local
.env.*.local

# Belt-and-suspenders: never commit Arduino secrets, even if the
# upstream-firmware/ ignore is ever removed or someone vendors the
# firmware in a different folder.
arduino_secrets.h
**/arduino_secrets.h
